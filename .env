# api2openclaw 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# 数据库配置
POSTGRES_DB=api2openclaw
POSTGRES_USER=api2openclaw
POSTGRES_PASSWORD=api2openclaw123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# JWT 配置
JWT_SECRET=change-this-secret-in-production-please-do

# 加密密钥（用于敏感字段加密）
ENCRYPTION_KEY=32-byte-encryption-key-1234

# API 配置
API_PORT=8080
API_BASE_PATH=/v1

# 前端配置
VITE_API_BASE_URL=http://localhost:8080/v1

# Prometheus 指标
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_PATH=/metrics

# 日志级别
LOG_LEVEL=info
LOG_FORMAT=json
