[Unit]
Description=api2openclaw - Local LLM Gateway & Format Converter
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=api2openclaw
Group=api2openclaw

# 工作目录
WorkingDirectory=/opt/api2openclaw

# 启动命令
ExecStart=/opt/api2openclaw/api2openclaw -config /etc/api2openclaw/config.yaml

# 重启配置
Restart=always
RestartSec=5
StartLimitInterval=0

# 安全配置
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/api2openclaw /var/lib/api2openclaw

# 资源限制
LimitNOFILE=65536
LimitNPROC=4096

# 环境变量
Environment="GIN_MODE=release"

[Install]
WantedBy=multi-user.target
